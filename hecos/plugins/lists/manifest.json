{
    "tag": "LISTS",
    "name": "Lists Manager",
    "version": "1.0.0",
    "description": "Universal list manager plugin. Supports shopping lists, to-do lists, blacklists, and any other list type with items, priorities, and labels.",
    "icon": "📋",
    "lazy_load": true,
    "is_class_based": true,
    "on_load": true,
    "status": "ONLINE",
    "config_schema": {
        "export_folder": {
            "type": "str",
            "default": "%USERPROFILE%\\Desktop",
            "description": "Default folder for exporting lists"
        }
    },
    "commands": {
        "create_list": "Crea una nuova lista vuota.",
        "list_lists": "Mostra tutte le liste attive con il conteggio degli elementi.",
        "show_list": "Mostra tutti gli elementi di una specifica lista.",
        "add_to_list": "Aggiunge uno o più elementi a una lista. Crea la lista se non esiste.",
        "check_item": "Segna un elemento come completato in una lista.",
        "uncheck_item": "Ripristina un elemento come da fare.",
        "remove_from_list": "Elimina definitivamente un elemento da una lista.",
        "clear_done": "Rimuove tutti gli elementi già completati da una lista.",
        "delete_list": "Elimina un'intera lista.",
        "archive_list": "Archivia una lista (la nasconde dalla visuale principale)."
    },
    "tool_schema": [
        {
            "type": "function",
            "function": {
                "name": "LISTS__create_list",
                "description": "Creates a new empty list. Use this when the user asks to 'create a list', 'crea la lista della spesa'.",
                "parameters": {
                    "type": "object",
                    "properties": {
                        "name": {
                            "type": "string",
                            "description": "The name of the list (e.g. 'Spesa', 'Cose da fare')."
                        },
                        "icon": {
                            "type": "string",
                            "description": "Optional emoji icon for the list."
                        }
                    },
                    "required": ["name"]
                }
            }
        },
        {
            "type": "function",
            "function": {
                "name": "LISTS__list_lists",
                "description": "Lists all active lists.",
                "parameters": {
                    "type": "object",
                    "properties": {}
                }
            }
        },
        {
            "type": "function",
            "function": {
                "name": "LISTS__show_list",
                "description": "Shows the content of a specific list. Use when user asks 'what's in the shopping list?', 'cosa c'è nella spesa?'.",
                "parameters": {
                    "type": "object",
                    "properties": {
                        "list_name": {
                            "type": "string",
                            "description": "The name of the list to show."
                        }
                    },
                    "required": ["list_name"]
                }
            }
        },
        {
            "type": "function",
            "function": {
                "name": "LISTS__add_to_list",
                "description": "Adds one or more items to a list. Use this when user says 'add milk to shopping list', 'aggiungi pane e latte alla spesa'.",
                "parameters": {
                    "type": "object",
                    "properties": {
                        "list_name": {
                            "type": "string",
                            "description": "The name of the list."
                        },
                        "items": {
                            "type": "string",
                            "description": "The item(s) to add. Can be a single item or multiple items separated by comma."
                        },
                        "priority": {
                            "type": "integer",
                            "description": "Optional priority: 0 (normal), 1 (high), 2 (urgent). Default is 0."
                        },
                        "label": {
                            "type": "string",
                            "description": "Optional category/label for the item."
                        }
                    },
                    "required": ["list_name", "items"]
                }
            }
        },
        {
            "type": "function",
            "function": {
                "name": "LISTS__check_item",
                "description": "Marks an item as done/completed. Use when user says 'I bought milk', 'ho preso il pane', 'spunta uova dalla spesa'.",
                "parameters": {
                    "type": "object",
                    "properties": {
                        "list_name": {
                            "type": "string",
                            "description": "The name of the list."
                        },
                        "item_text": {
                            "type": "string",
                            "description": "The text or partial text of the item to check."
                        }
                    },
                    "required": ["list_name", "item_text"]
                }
            }
        },
        {
            "type": "function",
            "function": {
                "name": "LISTS__uncheck_item",
                "description": "Restores a completed item back to pending.",
                "parameters": {
                    "type": "object",
                    "properties": {
                        "list_name": {
                            "type": "string",
                            "description": "The name of the list."
                        },
                        "item_text": {
                            "type": "string",
                            "description": "The item to restore."
                        }
                    },
                    "required": ["list_name", "item_text"]
                }
            }
        },
        {
            "type": "function",
            "function": {
                "name": "LISTS__remove_from_list",
                "description": "Deletes an item from a list completely.",
                "parameters": {
                    "type": "object",
                    "properties": {
                        "list_name": {
                            "type": "string",
                            "description": "The name of the list."
                        },
                        "item_text": {
                            "type": "string",
                            "description": "The item to remove."
                        }
                    },
                    "required": ["list_name", "item_text"]
                }
            }
        },
        {
            "type": "function",
            "function": {
                "name": "LISTS__clear_done",
                "description": "Clears all completed items from a list.",
                "parameters": {
                    "type": "object",
                    "properties": {
                        "list_name": {
                            "type": "string",
                            "description": "The name of the list to clean up."
                        }
                    },
                    "required": ["list_name"]
                }
            }
        }
    ],
    "slash_commands": [
        {
            "id": "lists",
            "aliases": ["/list", "/lists", "/liste"],
            "description": "Mostra tutte le liste",
            "usage": "/list",
            "example": "/list",
            "icon": "📋",
            "method": "list_lists",
            "args_schema": {},
            "requires_args": false
        },
        {
            "id": "list_show",
            "aliases": ["/lista"],
            "description": "Mostra una lista",
            "usage": "/lista <nome>",
            "example": "/lista Spesa",
            "icon": "🔍",
            "method": "show_list",
            "args_schema": {"list_name": "str"},
            "requires_args": true
        },
        {
            "id": "list_add",
            "aliases": ["/list add", "/lista aggiungi"],
            "description": "Aggiunge elemento",
            "usage": "/list add <lista> <elemento>",
            "example": "/list add Spesa Uova",
            "icon": "➕",
            "method": "add_to_list",
            "args_schema": {"list_name": "str", "items": "str"},
            "requires_args": true
        },
        {
            "id": "list_done",
            "aliases": ["/list done", "/lista spunta"],
            "description": "Spunta elemento",
            "usage": "/list done <lista> <elemento>",
            "example": "/list done Spesa Uova",
            "icon": "✅",
            "method": "check_item",
            "args_schema": {"list_name": "str", "item_text": "str"},
            "requires_args": true
        }
    ]
}
